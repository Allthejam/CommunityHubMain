rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             (
               request.auth.token.get('isAdmin', false) == true || 
               request.auth.uid == 'gx82VTPZkPTCHA4A7QV1WBpJ2802' ||
               (
                 exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                 (
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['admin', 'owner'] ||
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('accountType', '') in ['admin', 'owner'] ||
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get(['permissions', 'isAdmin'], false) == true
                 )
               )
             );
    }
    
    function isCommunityCreator() {
      return isSignedIn() && 
             request.auth.token.get('isCommunityCreator', false) == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isBusinessOwner(businessId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/businesses/$(businessId)) && 
             get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
    }

    function communityHasNoLeader(communityId) {
      return exists(/databases/$(database)/documents/communities/$(communityId)) && 
             get(/databases/$(database)/documents/communities/$(communityId)).data.get('leaderCount', 0) == 0;
    }

    function isLeaderOf(communityId) {
        return isSignedIn() && (
          isAdmin() || 
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
            (
              (
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('communityId', '') == communityId && 
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['president', 'leader', 'owner', 'admin', 'administrator', 'vice-president', 'moderator', 'editor', 'reporter', 'broadcaster']
              ) || (
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('communityRoles', null) != null && 
                communityId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.communityRoles && 
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.communityRoles[communityId].get('role', '') in ['president', 'leader', 'owner', 'admin', 'administrator', 'vice-president', 'moderator', 'editor', 'reporter', 'broadcaster']
              )
            )
          )
        );
    }

    function isCourierFor(communityId) {
      return isSignedIn() && (
        isAdmin() || 
        (
          exists(/databases/$(database)/documents/communities/$(communityId)) && 
          get(/databases/$(database)/documents/communities/$(communityId)).data.get('courierId', '') == request.auth.uid
        )
      );
    }

    function isPoliceLiaisonOf(communityId) {
      return isSignedIn() && (
        isAdmin() || 
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (
            (
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('communityId', '') == communityId && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'police-liaison-officer'
            ) || (
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('communityRoles', null) != null && 
              communityId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.communityRoles && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.communityRoles[communityId].get('role', '') == 'police-liaison-officer'
            )
          )
        )
      );
    }
    

    match /careers/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if true;
      allow create, update, delete: if isOwner(userId) || isAdmin();

      match /gallery/{itemId} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }
    }
    match /communities/{communityId} {
      allow create: if isCommunityCreator() || isAdmin();
      allow read: if true;
      allow update: if isLeaderOf(communityId) || isAdmin();
    }
    match /businesses/{businessId} {
      allow read: if true;
      allow create: if isBusinessOwner(businessId);
      allow update: if (isCommunityCreator() && communityHasNoLeader(resource.data.primaryCommunityId)) || isLeaderOf(resource.data.primaryCommunityId) || isAdmin() || isBusinessOwner(businessId);
    }
    match /businesses/{businessId}/products/{productId} {
        allow read: if true;
        allow write: if isBusinessOwner(businessId);

        match /product_data/{docId} {
            allow read: if true;
            allow write: if isBusinessOwner(businessId);
        }
    }
    match /whatson/{itemId} {
      allow create, update: if (isCommunityCreator() && communityHasNoLeader(request.resource.data.communityId)) || isLeaderOf(request.resource.data.communityId) || isAdmin();
      allow read: if true;
    }
    match /events/{eventId} {
      allow create, update: if (isCommunityCreator() && communityHasNoLeader(request.resource.data.communityId)) || isLeaderOf(request.resource.data.communityId) || isAdmin() || isBusinessOwner(request.resource.data.businessId);
      allow read: if true;
    }
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /news/{storyId} {
      allow read: if true;
      allow write: if isOwner(request.resource.data.authorId) || isLeaderOf(request.resource.data.communityId);
    }
    match /charities/{charityId} {
        allow read: if true;
        allow write: if isLeaderOf(request.resource.data.communityId) || isAdmin();
    }
    match /announcements/{docId} {
        allow read: if true;
        allow write: if isLeaderOf(request.resource.data.communityId) || isAdmin();
    }
     match /community_profiles/{profileId} {
      allow read: if true;
      allow write: if isLeaderOf(profileId) || isAdmin();
    }
    
    match /communities/{communityId}/posts/{postId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(request.resource.data.authorId) || isLeaderOf(communityId);
    }
    match /communities/{communityId}/posts/{postId}/comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
    }
    match /communities/{communityId}/marketplace/{itemId} {
        allow read: if isSignedIn();
        allow create: if isOwner(request.resource.data.ownerId);
        allow update, delete: if isOwner(resource.data.ownerId);
    }
    match /communities/{communityId}/polls/{pollId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
      allow update: if isSignedIn() && (
        isLeaderOf(communityId) || isAdmin() ||
        (
          !(request.auth.uid in resource.data.get('votedBy', [])) &&
          request.auth.uid in request.resource.data.get('votedBy', [])
        )
      );
    }
    match /jobSeekers/{seekerId} {
      allow read: if isSignedIn();
      allow write: if isOwner(request.resource.data.ownerId);
    }
     match /communities/{communityId}/faqs/{faqId} {
        allow read: if true;
        allow write: if isLeaderOf(communityId);
    }
    match /communities/{communityId}/guestbook/{entryId} {
        allow read: if (resource == null) || (resource.data.status == 'Live') || isLeaderOf(communityId) || isAdmin();
        allow create: if isSignedIn();
        allow update, delete: if isLeaderOf(communityId) || isAdmin();
    }

    match /liaison_applications/{applicationId} {
        allow create: if isSignedIn();
        allow read, update: if isLeaderOf(resource.data.communityId) || isAdmin();
    }
    match /couriers/{courierId} {
        allow read: if true;
        allow create, update: if isOwner(courierId) || isAdmin();
    }
    match /communities/{communityId}/courier_applications/{applicationId} {
        allow create: if isSignedIn();
        allow read, update: if isLeaderOf(communityId) || isAdmin();
    }

    match /orders/{orderId} {
      allow list: if isAdmin();
      
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.businessOwnerId == request.auth.uid || 
        isAdmin() ||
        isCourierFor(resource.data.communityId)
      );
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.businessOwnerId == request.auth.uid || 
        isCourierFor(resource.data.communityId) ||
        isAdmin()
      );
    }

    match /users/{userId}/recent_orders/{orderId} {
        allow read, write: if isOwner(userId);
    }
    
    match /audit_log/{logId} { allow read, write: if isAdmin(); }
    match /access_requests/{requestId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid) ||
        isAdmin()
      );
    }
    match /platform_reports/{reportId} { allow read, write: if isSignedIn(); }
    match /pricing_plans/{planId} { allow read, write: if isAdmin(); }
    match /platform_overview/{docId} { allow read, write: if isAdmin(); }
    match /platform_settings/{docId} { allow read, write: if isAdmin(); }
    match /legal_documents/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /marketing_campaigns/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /platform_marketing_gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /community_reports/{reportId} {
        allow create: if isSignedIn();
        allow read: if isLeaderOf(resource.data.communityId) || 
                      (isPoliceLiaisonOf(resource.data.communityId) && 
                       resource.data.category == 'report a crime');
        allow update: if isLeaderOf(resource.data.communityId);
    }

    match /adverts/{advertId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /forum-categories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /forum-topics/{topicId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /forum-topics/{topicId}/posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource == null || resource.data.recipientId == request.auth.uid || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn();
    }

    match /businesses/{businessId}/gallery/{itemId} {
      allow read: if true;
      allow write: if isBusinessOwner(businessId);
    }

    match /lostAndFound/{itemId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}